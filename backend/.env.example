# ============================================================
#  Study Bot AI Assistant — Environment Variables
#  Copy this to backend/.env and fill in your values.
#  NEVER commit .env to git.
# ============================================================

# ---- Server ----
PORT=3001
NODE_ENV=production

# ---- JWT (change to a long, random secret) ----
JWT_SECRET=your_very_long_random_jwt_secret_here

# ---- Groq AI API Key ----
# Get your free key at: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ---- CORS — Allowed Frontend Origin ----
# In production, set to your Railway/Render domain:
# FRONTEND_URL=https://your-app.up.railway.app
FRONTEND_URL=*
